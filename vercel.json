{
  "version": 2,
  "functions": {
    "pages/api/get.js": {
      "includeFiles": "**/*"
    },
    "pages/api/musixmatch.js": {
      "includeFiles": "**/*"
    }
  },
  "routes": [
    {
      "src": "/api/get",
      "methods": ["GET", "OPTIONS"],
      "dest": "/api/get.js"
    },
    {
      "src": "/api/musixmatch",
      "methods": ["GET", "OPTIONS"],
      "dest": "/api/musixmatch.js"
    }
  ]
}
